# Optional base URL for Infopunks Radar intelligence API.
# Leave blank to use mock radar signals.
RADAR_API_BASE_URL=

# Optional base URL for Pay.sh provider/catalog API.
# Leave blank to use mock provider catalog data.
PAYSH_API_BASE_URL=

# Enable live Pay.sh execution adapter.
# Set to true only when execution URL is configured.
LIVE_PAYSH_EXECUTION=false
PAYSH_EXECUTION_URL=
PAYSH_EXECUTION_METHOD=GET
PAYSH_EXECUTION_MODE=http
PAYSH_AUTH_HEADER=
PAYSH_AUTH_VALUE=
PAYSH_EXECUTION_HEADERS_JSON=
PAYSH_EXECUTION_BODY_JSON=

# Controlled communications benchmark recipient.
BENCHMARK_EMAIL_TO=
BENCHMARK_EMAIL_TO_CONTROLLED=false

# AgentMail paid send route requires an owned inbox id.
AGENTMAIL_INBOX_ID=

# Minimum trust score to consider a provider eligible.
# Range typically 0 to 100.
MIN_TRUST_SCORE=70

# Request timeout for external API calls.
REQUEST_TIMEOUT_MS=2500
