# Optional base URL for Infopunks Radar intelligence API.
# Leave blank to use mock radar signals.
RADAR_API_BASE_URL=

# Optional base URL for Pay.sh provider/catalog API.
# Leave blank to use mock provider catalog data.
PAYSH_API_BASE_URL=

# Minimum trust score to consider a provider eligible.
# Range typically 0 to 100.
MIN_TRUST_SCORE=70

# Request timeout for external API calls.
REQUEST_TIMEOUT_MS=2500
