{
  "type": "function",
  "function": {
    "name": "infopunks_pay_sh_harness",
    "description": "Preflight Infopunks Radar, optionally execute a verified Pay.sh route, and write a proof log before agent spend.",
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "intent": {
          "type": "string",
          "description": "Agent intent that needs provider routing."
        },
        "category": {
          "type": "string",
          "description": "Optional intent category (for example, finance or market_data)."
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minTrustScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "maxLatencyMs": {
              "type": "number",
              "minimum": 1
            },
            "maxCostUsd": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "endpointUrl": {
              "type": "string"
            },
            "method": {
              "type": "string"
            },
            "body": {},
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "proof": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "maxRetries": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": ["intent"]
    }
  }
}
