{
  "name": "@infopunks/pay-sh-harness",
  "version": "0.6.0",
  "private": false,
  "description": "Minimal TypeScript harness demonstrating Radar-assisted Pay.sh provider routing.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "license": "MIT",
  "scripts": {
    "demo:route": "ts-node src/demoRoute.ts",
    "demo:compare": "ts-node src/demoCompare.ts",
    "demo:live-market-data": "ts-node src/demoLiveMarketData.ts",
    "benchmark:live-market-data": "ts-node src/demoLiveMarketDataBenchmark.ts",
    "benchmark:live-head-to-head": "ts-node src/demoLiveHeadToHeadBenchmark.ts",
    "benchmark:live-rpc": "ts-node src/demoLiveRpcBenchmark.ts",
    "proof:solana-dex-pools": "ts-node src/demoProofSolanaDexPools.ts",
    "mappings:status": "ts-node src/demoMappingStatus.ts",
    "verify:mapping": "ts-node src/demoVerifyProviderMapping.ts",
    "intake:command": "ts-node src/providerIntakeCommand.ts",
    "debug:pay-cli-parity": "ts-node src/demoPayCliParity.ts",
    "benchmark": "ts-node src/demoBenchmark.ts",
    "test": "find src -name \"*.test.ts\" -print0 | xargs -0 node --test -r ts-node/register",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "benchmark:multi-category": "ts-node src/demoMultiCategoryBenchmark.ts",
    "diagnose:radar-preflight": "ts-node src/demoRadarPreflightDiagnostics.ts",
    "demo:agent-loop": "ts-node examples/agent-loop-demo.ts",
    "verify:paysponge-coingecko": "ts-node src/verifyPaySpongeCoinGecko.ts",
    "verify:paysponge-token-search": "ts-node src/verifyPaySpongeCoinGeckoTokenSearch.ts",
    "benchmark:sol-price": "tsx src/benchmarks/runSolPriceBenchmark.ts",
    "verify:paysponge-token-lookup-candidate": "ts-node src/verifyPaySpongeCoinGeckoTokenLookupCandidate.ts",
    "discover:token-search-routes": "tsx src/discoverTokenSearchRoutes.ts",
    "research:token-search-providers": "tsx src/tokenSearchProviderResearch.ts",
    "verify:stablecrypto-token-search-candidate": "ts-node src/verifyStablecryptoTokenSearchCandidate.ts",
    "benchmark:token-search": "tsx src/benchmarks/runTokenSearchBenchmark.ts",
    "research:token-metadata-providers": "tsx src/tokenMetadataProviderResearch.ts",
    "verify:token-metadata-candidates": "tsx src/verifyTokenMetadataCandidates.ts",
    "verify:communications-stableemail-paid": "tsx src/verifyCommunicationsStableemailPaid.ts",
    "verify:communications-agentmail-paid": "tsx src/verifyCommunicationsAgentmailPaid.ts",
    "verify:solana-balance-quicknode-paid": "tsx src/verifySolanaBalanceQuicknodePaid.ts",
    "verify:reddit-post-search-paid": "tsx src/verifyRedditPostSearchPaid.ts",
    "verify:web-search-paid": "tsx src/verifyWebSearchPaid.ts",
    "verify:document-ocr-paid": "tsx src/verifyDocumentOcrPaid.ts",
    "diagnose:reddit-stablesocial-shapes": "tsx src/diagnoseRedditStableSocialShapes.ts",
    "benchmark:web-search-live": "tsx src/benchmarkWebSearchLive.ts",
    "benchmark:document-ocr-live": "tsx src/benchmarkDocumentOcrLive.ts",
    "verify:maps-place-search-paid": "tsx src/verifyMapsPlaceSearchPaid.ts",
    "diagnose:maps-google-places-shapes": "tsx src/diagnoseMapsGooglePlacesShapes.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2"
  }
}
